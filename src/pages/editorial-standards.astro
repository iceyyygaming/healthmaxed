---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Editorial Standards — HealthMaxed" description="We evaluate products by evidence level, ingredient and feature transparency, claim risk, testing signals, real-world usefulness, and value. Affiliate ">
  <section class="hm-shell py-20">
    <div class="hm-card rounded-[2rem] p-8 md:p-12">
      <p class="hm-label">HealthMaxed</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight md:text-6xl">Editorial Standards</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[#2b302c]">We evaluate products by evidence level, ingredient and feature transparency, claim risk, testing signals, real-world usefulness, and value. Affiliate relationships do not change the standard.</p>
      <a href="/" class="mt-8 inline-block rounded-full bg-[#17201b] px-6 py-3 font-bold no-underline" style="color:#f7f3ea">Back home</a>
    </div>
  </section>
</BaseLayout>
