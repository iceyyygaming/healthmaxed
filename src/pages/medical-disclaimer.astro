---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Medical Disclaimer — HealthMaxed" description="HealthMaxed is for educational and informational purposes only. It is not medical advice, diagnosis, or treatment. Talk to a qualified clinician befor">
  <section class="hm-shell py-20">
    <div class="hm-card rounded-[2rem] p-8 md:p-12">
      <p class="hm-label">HealthMaxed</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight md:text-6xl">Medical Disclaimer</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[#2b302c]">HealthMaxed is for educational and informational purposes only. It is not medical advice, diagnosis, or treatment. Talk to a qualified clinician before changing supplements, routines, medications, or health protocols.</p>
      <a href="/" class="mt-8 inline-block rounded-full bg-[#17201b] px-6 py-3 font-bold no-underline" style="color:#f7f3ea">Back home</a>
    </div>
  </section>
</BaseLayout>
