---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/healthmaxxed';
---
<BaseLayout title="HealthMaxxed Categories — Supplements, hydration, sleep, recovery" description="Browse HealthMaxxed wellness product categories with transparent criteria and realistic claim checks.">
  <section class="hm-shell py-16 md:py-24">
    <p class="hm-label">Categories</p>
    <h1 class="mt-4 max-w-4xl text-5xl font-black tracking-tight md:text-7xl">Start with the category before the brand.</h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-[#2b302c]">A supplement only makes sense if the category makes sense for your routine, budget, and risk tolerance.</p>
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {categories.map((category) => (
        <a href={`/categories/${category.slug}`} class="hm-card block rounded-[1.5rem] p-6 no-underline transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="hm-label">{category.kicker}</div>
          <h2 class="mt-4 text-2xl font-black">{category.title}</h2>
          <p class="mt-3 leading-7 text-[#2b302c]">{category.description}</p>
          <div class="mt-5 flex flex-wrap gap-2 text-sm font-bold">
            <span class="rounded-full bg-[#dfe7dd] px-3 py-1">{category.evidence}</span>
            <span class="rounded-full bg-white px-3 py-1">{category.claimRisk}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
