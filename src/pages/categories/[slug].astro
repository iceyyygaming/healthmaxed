---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/healthmaxxed';
export function getStaticPaths() {
  return categories.map((category) => ({ params: { slug: category.slug }, props: { category } }));
}
const { category } = Astro.props;
---
<BaseLayout title={`${category.title} — HealthMaxxed`} description={category.description}>
  <section class="hm-shell py-14 md:py-20">
    <div class="grid gap-10 md:grid-cols-[1.05fr_.95fr]">
      <div>
        <p class="hm-label">{category.kicker}</p>
        <h1 class="mt-4 text-5xl font-black tracking-tight md:text-7xl">{category.title}</h1>
        <p class="mt-6 text-lg leading-8 text-[#2b302c]">{category.description}</p>
        <div class="mt-6 flex flex-wrap gap-2 text-sm font-bold">
          <span class="rounded-full bg-[#dfe7dd] px-3 py-1">{category.evidence}</span>
          <span class="rounded-full bg-white px-3 py-1">{category.claimRisk}</span>
        </div>
      </div>
      <aside class="hm-card rounded-[2rem] p-6">
        <p class="hm-label">Quick filter</p>
        <h2 class="mt-3 text-2xl font-black">What to look for</h2>
        <ul class="mt-5 grid gap-3">
          {category.whatToLookFor.map((item) => <li class="rounded-2xl bg-white/60 px-4 py-3 font-semibold">{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="hm-shell grid gap-6 md:grid-cols-2">
    <div class="hm-card rounded-[1.5rem] p-6">
      <h2 class="text-2xl font-black">Good fit for</h2>
      <ul class="mt-4 grid gap-3 text-[#2b302c]">{category.whoItsFor.map((item) => <li>• {item}</li>)}</ul>
    </div>
    <div class="hm-card rounded-[1.5rem] p-6">
      <h2 class="text-2xl font-black">Consider skipping if</h2>
      <ul class="mt-4 grid gap-3 text-[#2b302c]">{category.skipIf.map((item) => <li>• {item}</li>)}</ul>
    </div>
  </section>

  <section class="hm-shell py-16">
    <p class="hm-label">HealthMaxxed scoring</p>
    <h2 class="mt-3 text-4xl font-black tracking-tight">How we judge this category</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {category.scoring.map((item) => (
        <article class="rounded-[1.4rem] border border-[#17201b]/10 bg-white/50 p-5">
          <h3 class="font-black">{item.label}</h3>
          <p class="mt-2 leading-7 text-[#2b302c]">{item.note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-[#17201b] py-16 text-[#f7f3ea]">
    <div class="hm-shell">
      <p class="hm-label text-[#a9b99f]">Shortlist types</p>
      <h2 class="mt-3 text-4xl font-black tracking-tight">Product formats worth comparing</h2>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {category.productShortlist.map((product) => (
          <article class="rounded-[1.5rem] border border-white/10 bg-white/7 p-5">
            <div class="hm-label text-[#a9b99f]">{product.positioning}</div>
            <h3 class="mt-3 text-xl font-black">{product.name}</h3>
            <p class="mt-4 text-sm leading-6 text-[#dfe7dd]"><strong>Why:</strong> {product.why}</p>
            <p class="mt-3 text-sm leading-6 text-[#dfe7dd]"><strong>Watchout:</strong> {product.watchout}</p>
          </article>
        ))}
      </div>
      <p class="mt-6 text-sm text-[#dfe7dd]">Affiliate links and named brand picks can be added after hands-on or source-verified product research.</p>
    </div>
  </section>
</BaseLayout>
