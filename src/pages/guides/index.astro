---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { guideCards } from '../../data/healthmaxxed';
---
<BaseLayout title="HealthMaxxed Guides — Hype-checked wellness product research" description="Browse HealthMaxxed buyer guides for supplements, hydration, sleep, recovery, and clean routine upgrades.">
  <section class="hm-shell py-16 md:py-24">
    <p class="hm-label">Guide library</p>
    <h1 class="mt-4 max-w-4xl text-5xl font-black tracking-tight md:text-7xl">Research-first wellness buying guides.</h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-[#2b302c]">Every HealthMaxxed guide starts with the same question: what would make this product worth trusting, buying, skipping, or waiting on?</p>
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {guideCards.map((guide) => (
        <a href={guide.href} class="hm-card block rounded-[1.5rem] p-6 no-underline transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="hm-label">{guide.tag}</div>
          <h2 class="mt-4 text-2xl font-black">{guide.title}</h2>
          <p class="mt-3 leading-7 text-[#2b302c]">{guide.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
