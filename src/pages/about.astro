---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About HealthMaxxed — HealthMaxxed" description="HealthMaxxed is a wellness product intelligence project for people who want cleaner routines without falling for hype. We compare supplements, recovery">
  <section class="hm-shell py-20">
    <div class="hm-card rounded-[2rem] p-8 md:p-12">
      <p class="hm-label">HealthMaxxed</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight md:text-6xl">About HealthMaxxed</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[#2b302c]">HealthMaxxed is a wellness product intelligence project for people who want cleaner routines without falling for hype. We compare supplements, recovery tools, sleep upgrades, hydration products, and daily wellness gear using transparent standards.</p>
      <a href="/" class="mt-8 inline-block rounded-full bg-[#17201b] px-6 py-3 font-bold no-underline" style="color:#f7f3ea">Back home</a>
    </div>
  </section>
</BaseLayout>
