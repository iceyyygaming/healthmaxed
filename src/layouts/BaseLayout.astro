---
import '../styles/global.css';
const {
  title = 'HealthMaxed — Hype-checked wellness product guides',
  description = 'HealthMaxed helps you choose supplements, recovery tools, sleep upgrades, and daily wellness products with less hype and more transparency.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="hm-gradient min-h-screen">
    <header class="sticky top-0 z-20 border-b border-[rgba(23,32,27,.1)] bg-[#f7f3ea]/85 backdrop-blur-xl">
      <div class="hm-shell flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-3 no-underline" aria-label="HealthMaxed home">
          <span class="grid h-10 w-10 place-items-center rounded-2xl bg-[#17201b] text-[#f7f3ea] font-black">HM</span>
          <span>
            <span class="block text-lg font-black tracking-tight">HealthMaxed</span>
            <span class="hm-label block text-[10px]">Product intelligence</span>
          </span>
        </a>
        <nav class="hidden items-center gap-6 text-sm font-semibold text-[#2b302c] md:flex">
          <a href="/#guides" class="no-underline hover:text-[#66785f]">Guides</a>
          <a href="/#standards" class="no-underline hover:text-[#66785f]">Standards</a>
          <a href="/about" class="no-underline hover:text-[#66785f]">About</a>
          <a href="/#newsletter" class="hm-dark-cta rounded-full px-5 py-2.5 no-underline shadow-lg shadow-black/10">Join list</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="mt-24 border-t border-[rgba(23,32,27,.12)] bg-[#17201b] text-[#f7f3ea]">
      <div class="hm-shell grid gap-8 py-12 md:grid-cols-[1.2fr_.8fr_.8fr]">
        <div>
          <div class="text-2xl font-black">HealthMaxed</div>
          <p class="mt-3 max-w-md text-sm leading-6 text-[#dfe7dd]">Hype-checked wellness product guides for supplements, sleep, recovery, hydration, and daily routine upgrades.</p>
        </div>
        <div>
          <div class="hm-label text-[#a9b99f]">Trust</div>
          <div class="mt-3 grid gap-2 text-sm text-[#dfe7dd]">
            <a href="/editorial-standards">Editorial standards</a>
            <a href="/affiliate-disclosure">Affiliate disclosure</a>
            <a href="/medical-disclaimer">Medical disclaimer</a>
          </div>
        </div>
        <div>
          <div class="hm-label text-[#a9b99f]">Company</div>
          <div class="mt-3 grid gap-2 text-sm text-[#dfe7dd]">
            <a href="/about">About</a>
            <a href="/privacy">Privacy</a>
            <a href="mailto:hello@healthmaxxed.com">Contact</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
